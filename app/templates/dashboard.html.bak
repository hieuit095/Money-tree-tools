<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Passive Income Manager</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/htmx.org@1.9.10"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        gray: {
                            900: '#1a202c',
                            800: '#2d3748',
                            700: '#4a5568',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        .progress-bar { transition: width 0.5s ease-in-out; }
    </style>
</head>
<body class="bg-gray-900 text-white font-sans antialiased">
    <div class="min-h-screen bg-gradient-to-b from-gray-900 via-gray-900 to-black">
        <div class="container mx-auto px-4 py-8 max-w-6xl">
            <header class="mb-8">
                <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
                    <div>
                        <div class="flex items-center gap-3">
                            <div class="h-10 w-10 rounded-xl bg-gradient-to-br from-green-500 to-emerald-700 shadow-lg"></div>
                            <div>
                                <h1 class="text-2xl sm:text-3xl font-extrabold tracking-tight">Money Tree</h1>
                                <p class="text-sm text-gray-400">Monitor system health, manage containers, and configure platforms safely.</p>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <button hx-post="/control/stop/all" hx-swap="none" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2 px-4 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500/50 transition duration-150 ease-in-out">
                            Stop all services
                        </button>
                    </div>
                </div>
            </header>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-8">
                <div class="lg:col-span-2 bg-gray-800/60 border border-gray-700/60 rounded-2xl shadow-lg p-5">
                    <h2 class="text-lg font-bold">Quick start</h2>
                    <p class="text-sm text-gray-400 mt-1">Recommended order to get everything running without confusion.</p>
                    <ol class="mt-4 grid grid-cols-1 sm:grid-cols-3 gap-3">
                        <li class="rounded-xl bg-gray-900/40 border border-gray-700/40 p-4">
                            <div class="text-xs text-gray-400">Step 1</div>
                            <div class="font-semibold mt-1">Configure platforms</div>
                            <div class="text-sm text-gray-400 mt-1">Open Configuration and fill only the platforms you use.</div>
                        </li>
                        <li class="rounded-xl bg-gray-900/40 border border-gray-700/40 p-4">
                            <div class="text-xs text-gray-400">Step 2</div>
                            <div class="font-semibold mt-1">Save changes</div>
                            <div class="text-sm text-gray-400 mt-1">Save each platform section after updating credentials.</div>
                        </li>
                        <li class="rounded-xl bg-gray-900/40 border border-gray-700/40 p-4">
                            <div class="text-xs text-gray-400">Step 3</div>
                            <div class="font-semibold mt-1">Start services</div>
                            <div class="text-sm text-gray-400 mt-1">Use the Services table to start the containers you configured.</div>
                        </li>
                    </ol>
                </div>

                <div class="bg-gray-800/60 border border-gray-700/60 rounded-2xl shadow-lg p-5">
                    <h2 class="text-lg font-bold">System status</h2>
                    <p class="text-sm text-gray-400 mt-1">Updates every 3 seconds.</p>
                    <div class="mt-4 grid grid-cols-1 gap-3">
                        <div class="rounded-xl bg-gray-900/40 border border-gray-700/40 p-4">
                            <div class="flex items-center justify-between">
                                <div class="text-xs text-gray-400 font-semibold uppercase tracking-wide">CPU</div>
                                <div class="text-xs text-gray-500"><span id="cpu-temp">0°C</span></div>
                            </div>
                            <div class="mt-2 flex items-end justify-between">
                                <div id="cpu-usage" class="text-3xl font-extrabold">0%</div>
                                <div class="text-xs text-gray-500">Load</div>
                            </div>
                            <div class="w-full bg-gray-700/60 rounded-full h-2.5 mt-3">
                                <div id="cpu-bar" class="bg-gradient-to-r from-blue-500 to-cyan-400 h-2.5 rounded-full progress-bar" style="width: 0%"></div>
                            </div>
                        </div>

                        <div class="rounded-xl bg-gray-900/40 border border-gray-700/40 p-4">
                            <div class="flex items-center justify-between">
                                <div class="text-xs text-gray-400 font-semibold uppercase tracking-wide">Memory</div>
                                <div class="text-xs text-gray-500">Swap <span id="swap-percent">0%</span></div>
                            </div>
                            <div class="mt-2 flex items-end justify-between gap-3">
                                <div class="min-w-0">
                                    <div class="text-sm text-gray-400 truncate">Used <span id="ram-used">0</span> / <span id="ram-total">0</span> GB</div>
                                    <div id="ram-percent" class="text-2xl font-extrabold mt-1">0%</div>
                                </div>
                            </div>
                            <div class="w-full bg-gray-700/60 rounded-full h-2.5 mt-3">
                                <div id="ram-bar" class="bg-gradient-to-r from-purple-500 to-fuchsia-400 h-2.5 rounded-full progress-bar" style="width: 0%"></div>
                            </div>
                        </div>

                        <div class="rounded-xl bg-gray-900/40 border border-gray-700/40 p-4">
                            <div class="text-xs text-gray-400 font-semibold uppercase tracking-wide">Network</div>
                            <div class="mt-2 grid grid-cols-2 gap-3">
                                <div class="rounded-lg bg-gray-800/40 border border-gray-700/40 p-3">
                                    <div class="text-xs text-gray-500">Download</div>
                                    <div class="text-lg font-bold text-green-400">↓ <span id="net-down">0</span> KB/s</div>
                                </div>
                                <div class="rounded-lg bg-gray-800/40 border border-gray-700/40 p-3">
                                    <div class="text-xs text-gray-500">Upload</div>
                                    <div class="text-lg font-bold text-blue-400">↑ <span id="net-up">0</span> KB/s</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                <section class="lg:col-span-2 bg-gray-800/60 border border-gray-700/60 rounded-2xl shadow-lg overflow-hidden">
                    <div class="p-5 border-b border-gray-700/60 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                        <div>
                            <h2 class="text-lg font-bold">Services</h2>
                            <p class="text-sm text-gray-400">Start only the services you configured. Auto-refresh: 3s</p>
                        </div>
                        <div class="w-full sm:w-64">
                            <input id="service-filter" type="text" placeholder="Filter services (e.g. honeygain)" class="w-full rounded-lg bg-gray-900/40 border border-gray-700/60 px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500/30">
                        </div>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-gray-900/40 text-gray-300 text-xs uppercase tracking-wide">
                                    <th class="p-4">Service</th>
                                    <th class="p-4">Status</th>
                                    <th class="p-4">Memory</th>
                                    <th class="p-4 text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody id="docker-list" class="text-sm">
                                <tr><td colspan="4" class="p-4 text-center text-gray-500">Loading...</td></tr>
                            </tbody>
                        </table>
                    </div>
                </section>

                <section class="bg-gray-800/60 border border-gray-700/60 rounded-2xl shadow-lg overflow-hidden">
                    <div class="p-5 border-b border-gray-700/60">
                        <h2 class="text-lg font-bold">Configuration</h2>
                        <p class="text-sm text-gray-400 mt-1">Credentials are stored in the .env file on the server.</p>
                    </div>

                    <div class="p-3">
                        <div class="space-y-2">
                            {% for section in sections %}
                            {% set ns = namespace(missing=0) %}
                            {% for f in section.fields %}
                                {% if not config.get(f.key) %}
                                    {% set ns.missing = ns.missing + 1 %}
                                {% endif %}
                            {% endfor %}
                            <details class="group rounded-xl bg-gray-900/40 border border-gray-700/60 overflow-hidden">
                                <summary class="cursor-pointer list-none px-4 py-3 flex items-start justify-between gap-3">
                                    <div class="min-w-0">
                                        <div class="font-semibold truncate">{{ section.title }}</div>
                                        <div class="text-xs text-gray-400 mt-0.5">{{ section.subtitle }}</div>
                                    </div>
                                    <div class="flex items-center gap-2 pt-0.5">
                                        {% if ns.missing == 0 %}
                                            <span class="text-xs font-semibold px-2 py-1 rounded-full bg-green-500/15 text-green-300 border border-green-500/20">Ready</span>
                                        {% else %}
                                            <span class="text-xs font-semibold px-2 py-1 rounded-full bg-yellow-500/15 text-yellow-200 border border-yellow-500/20">Missing {{ ns.missing }}</span>
                                        {% endif %}
                                        <span class="text-gray-500 transition group-open:rotate-180">▾</span>
                                    </div>
                                </summary>
                                <div class="px-4 pb-4">
                                    {% if section.instructions %}
                                        <div class="mt-2 rounded-lg bg-gray-800/40 border border-gray-700/40 p-3">
                                            <div class="text-xs font-semibold text-gray-300 uppercase tracking-wide">How to configure</div>
                                            <ul class="mt-2 space-y-1 text-sm text-gray-300">
                                                {% for line in section.instructions %}
                                                <li class="leading-snug">• {{ line }}</li>
                                                {% endfor %}
                                            </ul>
                                        </div>
                                    {% endif %}

                                    <form action="/save-config" method="POST" class="mt-3 grid grid-cols-1 gap-3">
                                        {% for f in section.fields %}
                                        <div>
                                            <label class="block text-xs font-bold text-gray-400 mb-1" for="{{ f.key }}">{{ f.label }}</label>
                                            <div class="relative">
                                                <input
                                                    class="w-full rounded-lg bg-gray-900/40 border border-gray-700/60 px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500/30 pr-16"
                                                    id="{{ f.key }}"
                                                    name="{{ f.key }}"
                                                    type="{{ 'password' if f.sensitive else 'text' }}"
                                                    value="{{ config.get(f.key, '') }}"
                                                    placeholder="{{ f.placeholder }}"
                                                    autocomplete="off"
                                                >
                                                {% if f.sensitive %}
                                                <button type="button" class="absolute right-2 top-1/2 -translate-y-1/2 text-xs font-semibold px-2 py-1 rounded-md bg-gray-700/50 hover:bg-gray-700 text-gray-200 border border-gray-600/60" onclick="toggleSecret('{{ f.key }}', this)">
                                                    Show
                                                </button>
                                                {% endif %}
                                            </div>
                                            <div class="text-xs text-gray-500 mt-1">{{ f.help }}</div>
                                        </div>
                                        {% endfor %}
                                        <button class="mt-1 bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-lg w-full transition duration-150 ease-in-out" type="submit">
                                            Save {{ section.title }}
                                        </button>
                                    </form>
                                </div>
                            </details>
                            {% endfor %}
                        </div>

                        <details class="group mt-3 rounded-xl bg-gray-900/30 border border-gray-700/50 overflow-hidden">
                            <summary class="cursor-pointer list-none px-4 py-3 flex items-center justify-between">
                                <span class="font-semibold">Advanced: all environment variables</span>
                                <span class="text-gray-500 transition group-open:rotate-180">▾</span>
                            </summary>
                            <div class="px-4 pb-4">
                                <form action="/save-config" method="POST" class="grid grid-cols-1 gap-3">
                                    {% for field in fields %}
                                    <div>
                                        <label class="block text-xs font-bold text-gray-400 mb-1" for="all_{{ field }}">{{ field }}</label>
                                        <input
                                            class="w-full rounded-lg bg-gray-900/40 border border-gray-700/60 px-3 py-2 text-sm text-gray-200 placeholder:text-gray-500 focus:outline-none focus:ring-2 focus:ring-green-500/30"
                                            id="all_{{ field }}"
                                            name="{{ field }}"
                                            type="{{ 'password' if ('PASS' in field or 'PASSWORD' in field or 'TOKEN' in field or 'API_KEY' in field) else 'text' }}"
                                            value="{{ config.get(field, '') }}"
                                            placeholder="..."
                                            autocomplete="off"
                                        >
                                    </div>
                                    {% endfor %}
                                    <button class="bg-green-600 hover:bg-green-700 text-white font-semibold py-2 px-4 rounded-lg w-full transition duration-150 ease-in-out" type="submit">
                                        Save all
                                    </button>
                                </form>
                            </div>
                        </details>
                    </div>
                </section>
            </div>
        </div>
    </div>

    <script>
        function formatBytes(bytes, decimals = 2) {
            if (!+bytes) return '0 B';
            const k = 1024;
            const dm = decimals < 0 ? 0 : decimals;
            const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return `${parseFloat((bytes / Math.pow(k, i)).toFixed(dm))} ${sizes[i]}`;
        }

        function toggleSecret(inputId, buttonEl) {
            const input = document.getElementById(inputId);
            if (!input) return;
            const isPassword = input.getAttribute('type') === 'password';
            input.setAttribute('type', isPassword ? 'text' : 'password');
            buttonEl.textContent = isPassword ? 'Hide' : 'Show';
        }

        function updateStats() {
            fetch('/api/stats')
                .then(response => response.json())
                .then(data => {
                    document.getElementById('cpu-usage').innerText = `${data.cpu.usage}%`;
                    document.getElementById('cpu-temp').innerText = `${data.cpu.temp}°C`;
                    document.getElementById('cpu-bar').style.width = `${data.cpu.usage}%`;
                    
                    const usedGB = (data.memory.used / 1024 / 1024 / 1024).toFixed(2);
                    const totalGB = (data.memory.total / 1024 / 1024 / 1024).toFixed(2);
                    document.getElementById('ram-used').innerText = usedGB;
                    document.getElementById('ram-total').innerText = totalGB;
                    document.getElementById('ram-percent').innerText = `${data.memory.percent}%`;
                    document.getElementById('ram-bar').style.width = `${data.memory.percent}%`;
                    document.getElementById('swap-percent').innerText = `${data.memory.swap_percent}%`;
                    
                    const downKB = (data.network.down / 1024).toFixed(1);
                    const upKB = (data.network.up / 1024).toFixed(1);
                    document.getElementById('net-down').innerText = downKB;
                    document.getElementById('net-up').innerText = upKB;
                });
        }

        function updateContainers() {
            fetch('/api/containers')
                .then(response => response.json())
                .then(data => {
                    const tbody = document.getElementById('docker-list');
                    tbody.innerHTML = '';
                    
                    if (data.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="4" class="p-3 text-center text-gray-500">No containers found</td></tr>';
                        return;
                    }

                    data.forEach(c => {
                        const isRunning = c.status === 'running';
                        const statusBadge = isRunning
                            ? '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold bg-green-500/15 text-green-300 border border-green-500/20">running</span>'
                            : '<span class="inline-flex items-center px-2 py-1 rounded-full text-xs font-semibold bg-red-500/15 text-red-300 border border-red-500/20">stopped</span>';
                        const actionBtn = isRunning 
                            ? `<button hx-post="/control/stop/${c.name}" hx-swap="none" onclick="setTimeout(updateContainers, 1000)" class="text-xs bg-red-600 hover:bg-red-700 text-white py-1 px-2 rounded">Stop</button>`
                            : `<button hx-post="/control/start/${c.name}" hx-swap="none" onclick="setTimeout(updateContainers, 1000)" class="text-xs bg-green-600 hover:bg-green-700 text-white py-1 px-2 rounded">Start</button>`;
                        
                        const memDisplay = isRunning ? formatBytes(c.memory) : '-';

                        const row = `
                            <tr class="border-b border-gray-700/60 hover:bg-gray-900/30 service-row" data-service-name="${c.name.toLowerCase()}">
                                <td class="p-3 font-medium">${c.name}</td>
                                <td class="p-3">${statusBadge}</td>
                                <td class="p-3 text-gray-400">${memDisplay}</td>
                                <td class="p-3 text-right">
                                    ${actionBtn}
                                </td>
                            </tr>
                        `;
                        tbody.innerHTML += row;
                    });
                    
                    htmx.process(tbody);
                    applyServiceFilter();
                });
        }

        function applyServiceFilter() {
            const input = document.getElementById('service-filter');
            if (!input) return;
            const q = (input.value || '').toLowerCase().trim();
            const rows = document.querySelectorAll('.service-row');
            rows.forEach(row => {
                const name = row.getAttribute('data-service-name') || '';
                row.style.display = !q || name.includes(q) ? '' : 'none';
            });
        }

        updateStats();
        updateContainers();

        setInterval(updateStats, 3000);
        setInterval(updateContainers, 3000);

        document.addEventListener('input', (e) => {
            if (e.target && e.target.id === 'service-filter') {
                applyServiceFilter();
            }
        });
    </script>
</body>
</html>
